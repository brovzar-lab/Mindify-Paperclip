rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function onlyChangedFields(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // Users own their profile doc; nobody else can read or write it.
    // The `entities` map is written here when the user approves an
    // EntitySuggestionDoc.
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Recordings: only Cloud Functions create/update; users can read their own.
    match /recordings/{recordingId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // Items: Cloud Functions create; users can read their own, mark them
    // complete (set completedAt), snooze (change bucket), assign a topic
    // (set topicId after approving a suggestion), and delete. Other
    // classification fields are immutable from the client.
    match /items/{itemId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && onlyChangedFields(['completedAt', 'bucket', 'topicId']);
    }

    // Groups: Cloud Functions create; users can read their own, rename, or delete.
    match /groups/{groupId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && onlyChangedFields(['title']);
    }

    // Topics: users create these client-side when approving a suggestion,
    // and can rename or delete their own. Cloud Functions also update
    // itemIds / itemCount / lastUpdatedAt on topicMatch writes.
    match /topics/{topicId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
    }

    // TopicSuggestions: Cloud Functions create pending ones; users read and
    // flip status (approve/reject) on their own suggestions.
    match /topicSuggestions/{suggestionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && onlyChangedFields(['status']);
    }

    // EntitySuggestions: same pattern as topic suggestions. The user also
    // edits the persisted entity through users/{uid}.entities on approval.
    match /entitySuggestions/{suggestionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && onlyChangedFields(['status', 'relationship']);
    }

    // Per-recording cost ledger written by processRecording. Clients never
    // need these — cost dashboards run server-side against the Admin SDK.
    match /costs/{userId}/{month}/{recordingId} {
      allow read, write: if false;
    }

    // Per-user rate-limit counter. Server-only.
    match /rateLimit/{userId} {
      allow read, write: if false;
    }
  }
}
